{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "opening.schema.json",
  "title": "Opening Metadata",
  "description": "Schema for an opening repertoire's top-level metadata file (metadata.json).",
  "type": "object",
  "required": [
    "id",
    "name",
    "slug",
    "ecoRange",
    "family",
    "colour",
    "popularity",
    "difficulty",
    "description",
    "strategicOverview",
    "typicalPawnStructures",
    "commonTacticalThemes",
    "modelPlayers",
    "recommendedStudyOrder",
    "baseMoves",
    "masteryLevels"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique kebab-case identifier for this opening."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable opening name."
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-safe slug, typically matches id."
    },
    "ecoRange": {
      "type": "string",
      "pattern": "^[A-E][0-9]{2}(–[A-E][0-9]{2})?$",
      "description": "ECO code or range (e.g. 'C50' or 'C50–C59')."
    },
    "family": {
      "type": "string",
      "description": "Opening family (e.g. 'King Pawn', 'Queen Pawn', 'Flank')."
    },
    "colour": {
      "type": "string",
      "enum": ["white", "black"],
      "description": "The side this repertoire is designed for."
    },
    "popularity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Popularity rating from 1 (rare) to 5 (very common)."
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Difficulty rating from 1 (beginner-friendly) to 5 (highly theoretical)."
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "description": "Short prose description of the opening."
    },
    "strategicOverview": {
      "type": "string",
      "minLength": 20,
      "description": "In-depth strategic overview for study purposes."
    },
    "typicalPawnStructures": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Named pawn structures commonly arising from this opening."
    },
    "commonTacticalThemes": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Tactical themes the student should learn."
    },
    "modelPlayers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Grandmasters historically associated with this opening."
    },
    "recommendedStudyOrder": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Ordered list of related opening IDs to study before or alongside."
    },
    "baseMoves": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "SAN move list defining the opening's starting position."
    },
    "masteryLevels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "tier", "objectives", "expectedKnowledge", "averageMoveDepth", "averageLineCount", "xpReward", "graduationRequirements"],
        "properties": {
          "level": { "type": "integer", "minimum": 1, "maximum": 7 },
          "tier": { "type": "string", "enum": ["Beginner", "Novice", "Intermediate", "Advanced", "Expert", "Master", "Legend"] },
          "objectives": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "expectedKnowledge": { "type": "string", "minLength": 10 },
          "averageMoveDepth": { "type": "integer", "minimum": 1 },
          "averageLineCount": { "type": "integer", "minimum": 1 },
          "xpReward": { "type": "integer", "minimum": 1 },
          "graduationRequirements": { "type": "string", "minLength": 10 }
        },
        "additionalProperties": false
      },
      "minItems": 7,
      "maxItems": 7,
      "description": "The seven mastery tiers and their definitions for this opening."
    }
  },
  "additionalProperties": false
}
