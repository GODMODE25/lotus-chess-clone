rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requester is the document owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users collection — each user can read/write only their own document
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Progress sub-collection under each user
      match /progress/{lessonId} {
        allow read, write: if isOwner(userId);
      }

      // Custom variations sub-collection under each user
      match /customVariations/{variationId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Global opening catalog — readable by all authenticated users, writable by admins
    match /openings/{openingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Global endgame catalog — readable by all authenticated users, writable by admins
    match /endgames/{endgameId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Deny all other paths by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
